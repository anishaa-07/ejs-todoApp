<link rel="stylesheet" href="/styles.css" />

<div class="container">

  <!-- Header -->
  <div class="header">
    <h2>My Todos</h2>
    <form action="/logout">
      <button class="logout">Logout</button>
    </form>
  </div>

  <!-- Card -->
  <div class="card">

    <!-- Input -->
    <form method="POST" action="/todos/add" class="todo-input">
      <input name="title" placeholder="What needs to be done?" required />
      <button type="submit">Add</button>
    </form>

    <!-- Todo List -->
    <ul>
      <% if (todos.length === 0) { %>
        <div class="empty">
          <p>No todos yet</p>
          <small>Add something to get started</small>
        </div>
      <% } %>

      <% todos.forEach(todo => { %>
        <li>
          <span class="todo-text <%= todo.completed ? 'completed' : '' %>">
            <%= todo.title %>
          </span>

          <div class="actions">
            <form method="POST" action="/todos/toggle/<%= todo._id %>">
              <button class="icon-btn toggle-btn">
                <%= todo.completed ? 'Undo' : 'Done' %>
              </button>
            </form>

            <form method="POST" action="/todos/delete/<%= todo._id %>">
              <button class="icon-btn delete-btn">Delete</button>
            </form>
          </div>
        </li>
      <% }) %>
    </ul>

  </div>
</div>